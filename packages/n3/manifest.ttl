@base <https://barnard59.zazuko.com/operations/n3/> .
@prefix code: <https://code.described.at/> .
@prefix p: <https://pipeline.described.at/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix b59: <https://barnard59.zazuko.com/vocab#> .

<applyRules> a p:Operation, p:Readable;
  rdfs:label "Apply N3 Rules";
  rdfs:comment "Applies N3 rules to datasets in barnard59 pipelines";
  code:implementedBy [ a code:EcmaScriptModule;
    code:link <node:barnard59-n3/applyRules.js#default>
  ].

<command/applyRules>
  a b59:CliCommand ;
  b59:command "apply" ;
  rdfs:label "Applies N3 rules to datasets in barnard59 pipelines" ;
  b59:source "barnard59-n3/pipeline/applyRules.ttl" ;
  b59:pipeline <https://barnard59.zazuko.com/pipeline/n3/apply> ;
.